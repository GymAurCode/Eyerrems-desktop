{
  "name": "EyerREMS",
  "private": true,
  "version": "1.0.2",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:vite": "vite build",
    "build:electron": "electron-builder --win --x64",
    "build:all": "vite build && electron-builder --win --x64",
    "release": "vite build && electron-builder --win --x64 --publish always",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.9.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "hyperformula": "^3.3.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.rems.desktop",
    "productName": "EyerRems",
    "copyright": "Copyright © 2026 EyerREMS",
    "icon": "assets/icon.ico",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.exe",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EyerRems"
    },
    "portable": {
      "artifactName": "${productName}-portable-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "GymAurCode",
      "repo": "Eyerrems-desktop",
      "releaseType": "release"
    },
    "generateUpdatesFilesForAllChannels": true,
    "directories": {
      "output": "dist_electron"
    }
  }
}
