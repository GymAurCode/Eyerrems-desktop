# Direct API URL (optional). If unset in dev, requests use the Vite dev server + proxy (recommended).
# If set, it must be the exact FastAPI origin (no /api suffix). Must match your uvicorn port.
# VITE_API_URL=http://127.0.0.1:8001

# Where Vite proxies /auth, /crm, etc. MUST match `uvicorn ... --port` (default in vite.config is 8001).
VITE_PROXY_TARGET=http://127.0.0.1:8001

# Finance microservice URL (Node.js + Express + SQLite, runs on port 3001)
VITE_FINANCE_URL=http://localhost:3001
